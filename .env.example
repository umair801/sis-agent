# App
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_DEBUG=true
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:password@db:5432/sis_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI / LLM
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
PRIMARY_LLM=claude-sonnet-4-20250514
FALLBACK_LLM=gpt-4o

# Vector Store
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=sis-rag

# JWT
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_URL=redis://redis:6379/0

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@sis.datawebify.com

# Railway
RAILWAY_ENVIRONMENT=production
PORT=8000
